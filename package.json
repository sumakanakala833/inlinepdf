    "motion": "^12.38.0",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-image-crop": "^11.0.10",
    "react-resizable-panels": "^4.7.3",
    "react-router": "^7.13.1",
    "react-zoom-pan-pinch": "^3.7.0",
